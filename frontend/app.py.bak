.tab{flex:1;text-align:center;font-size:17px;font-weight:400;color:#455972;padding-bottom:13px;border-bottom:2px solid transparent;margin-bottom:-1px;cursor:pointer;transition:color 160ms,border-color 160ms;background:none;border-left:none;border-right:none;border-top:none;font-family:inherit}
