<body>
<div class="card">
  <div class="logo">
    <div class="logo-icon">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
        <circle cx="8" cy="8" r="5" stroke="#4F9CF9" stroke-width="1.4"/>
        <circle cx="8" cy="8" r="2" fill="#4F9CF9"/>
      </svg>
    </div>
    <span class="logo-name">AI Digital Twin</span>
  </div>

  <div class="alert-err" id="alertErr"></div>
  <div class="alert-ok"  id="alertOk"></div>

  <div id="fpBlock" style="display:none">
    <div id="fp1">
      <span class="step-badge">Step 1 of 3 - Email address</span>
      <div class="field"><label class="lbl">Registered email</label>
        <input type="email" id="fpEmail" placeholder="you@example.com"/></div>
      <button class="btn" onclick="submitFP1()">Send reset code</button>
      <div style="text-align:center;margin-top:12px">
        <button class="otp-link" onclick="showMain()">Back to sign in</button></div>
    </div>
    <div id="fp2" style="display:none">
      <span class="step-badge">Step 2 of 3 - Verify code</span>
      <p class="hint">Code sent to <b id="fp2Email"></b>. Expires in 10 min.</p>
      <div class="field"><label class="lbl">6-digit code</label>
        <input type="text" id="fpOtp" placeholder="000000" maxlength="6"/></div>
      <button class="btn" onclick="submitFP2()">Verify code</button>
      <div style="text-align:center;margin-top:12px">
        <button class="otp-link" onclick="showFP1()">Resend code</button></div>
    </div>
    <div id="fp3" style="display:none">
      <span class="step-badge">Step 3 of 3 - New password</span>
      <div class="field"><label class="lbl">New password</label>
        <input type="password" id="fpNewPw" placeholder="Min. 6 characters"/></div>
      <div class="field"><label class="lbl">Confirm password</label>
        <input type="password" id="fpConfPw" placeholder="Re-enter password"/></div>
      <button class="btn" onclick="submitFP3()">Reset password</button>
      <div style="text-align:center;margin-top:12px">
        <button class="otp-link" onclick="showFP2From3()">Back</button></div>
    </div>
  </div>

  <div id="mainBlock">
    <div class="tabs">
      <button class="tab active" id="tabLogin"    onclick="switchTab('login')">Sign in</button>
      <button class="tab"        id="tabRegister" onclick="switchTab('register')">Create account</button>
    </div>

    <div class="panel active" id="panelLogin">
      <div class="method-row">
        <button class="method-btn active" id="mPwd" onclick="switchMethod('pwd')">Password</button>
        <button class="method-btn"        id="mOtp" onclick="switchMethod('otp')">Email code</button>
      </div>

      <div id="pwdFlow">
        <div class="field"><label class="lbl">Email</label>
          <input type="email" id="loginEmail" placeholder="you@example.com"/></div>
        <div class="field"><label class="lbl">Password</label>
          <input type="password" id="loginPwd" placeholder="**********"
            onkeydown="if(event.key==='Enter')submitLogin()"/></div>
        <div class="forgot"><a onclick="showFP1()">Forgot password?</a></div>
        <button class="btn" onclick="submitLogin()">Continue</button>
        <div class="divider"><div class="divider-line"></div><span class="divider-text">or</span><div class="divider-line"></div></div>
        <button class="g-btn">
          <svg width="15" height="15" viewBox="0 0 18 18" fill="none">
            <path d="M17.64 9.2c0-.637-.057-1.251-.164-1.84H9v3.481h4.844a4.14 4.14 0 01-1.796 2.716v2.259h2.908c1.702-1.567 2.684-3.875 2.684-6.615z" fill="#4285F4"/>
            <path d="M9 18c2.43 0 4.467-.806 5.956-2.184l-2.908-2.259c-.806.54-1.837.859-3.048.859-2.344 0-4.328-1.584-5.036-3.711H.957v2.332A8.997 8.997 0 009 18z" fill="#34A853"/>
            <path d="M3.964 10.705A5.41 5.41 0 013.682 9c0-.593.102-1.17.282-1.705V4.963H.957A8.996 8.996 0 000 9c0 1.452.348 2.827.957 4.037l3.007-2.332z" fill="#FBBC05"/>
            <path d="M9 3.58c1.321 0 2.508.454 3.44 1.345l2.582-2.58C13.463.891 11.426 0 9 0A8.997 8.997 0 00.957 4.963L3.964 7.295C4.672 5.168 6.656 3.58 9 3.58z" fill="#EA4335"/>
          </svg>
          Continue with Google
        </button>
      </div>

      <div id="otpFlow" style="display:none">
        <div id="otpStep1">
          <span class="step-badge">Step 1 of 2 - Email address</span>
          <div class="field"><label class="lbl">Registered email</label>
            <input type="email" id="otpEmail" placeholder="you@example.com"/></div>
          <button class="btn" onclick="submitOTPSend()">Send one-time code</button>
        </div>
        <div id="otpStep2" style="display:none">
          <span class="step-badge">Step 2 of 2 - Enter code</span>
          <p class="hint">Code sent to <b id="otpEmailDisplay"></b>. Expires in 10 min.</p>
          <div class="field"><label class="lbl">6-digit code</label>
            <input type="text" id="otpCode" placeholder="000000" maxlength="6"
              style="letter-spacing:6px;font-size:18px;text-align:center"
              onkeydown="if(event.key==='Enter')submitOTPVerify()"/></div>
          <button class="btn" onclick="submitOTPVerify()">Verify and sign in</button>
          <div style="text-align:center;margin-top:12px">
            <button class="otp-link" onclick="backOTPStep1()">Resend code</button></div>
        </div>
      </div>

      <p class="footer">By continuing you agree to our
        <a href="#">Terms of Service</a> and <a href="#">Privacy Policy</a></p>
    </div>

    <div class="panel" id="panelRegister">
      <div class="field"><label class="lbl">Full name</label>
        <input type="text" id="regName" placeholder="Alex Sharma"/></div>
      <div class="field"><label class="lbl">Email</label>
        <input type="email" id="regEmail" placeholder="you@example.com"/></div>
      <div class="field"><label class="lbl">Password</label>
        <input type="password" id="regPwd" placeholder="Min. 6 characters"/></div>
      <div class="field"><label class="lbl">Confirm password</label>
        <input type="password" id="regConfPwd" placeholder="Re-enter password"
          onkeydown="if(event.key==='Enter')submitRegister()"/></div>
      <button class="btn" onclick="submitRegister()" style="margin-top:8px">Create account</button>
      <div class="divider"><div class="divider-line"></div><span class="divider-text">or</span><div class="divider-line"></div></div>
      <button class="g-btn">
        <svg width="15" height="15" viewBox="0 0 18 18" fill="none">
          <path d="M17.64 9.2c0-.637-.057-1.251-.164-1.84H9v3.481h4.844a4.14 4.14 0 01-1.796 2.716v2.259h2.908c1.702-1.567 2.684-3.875 2.684-6.615z" fill="#4285F4"/>
          <path d="M9 18c2.43 0 4.467-.806 5.956-2.184l-2.908-2.259c-.806.54-1.837.859-3.048.859-2.344 0-4.328-1.584-5.036-3.711H.957v2.332A8.997 8.997 0 009 18z" fill="#34A853"/>
          <path d="M3.964 10.705A5.41 5.41 0 013.682 9c0-.593.102-1.17.282-1.705V4.963H.957A8.996 8.996 0 000 9c0 1.452.348 2.827.957 4.037l3.007-2.332z" fill="#FBBC05"/>
          <path d="M9 3.58c1.321 0 2.508.454 3.44 1.345l2.582-2.58C13.463.891 11.426 0 9 0A8.997 8.997 0 00.957 4.963L3.964 7.295C4.672 5.168 6.656 3.58 9 3.58z" fill="#EA4335"/>
        </svg>
        Continue with Google
      </button>
      <p class="footer" style="margin-top:14px">
        Already have an account? <a onclick="switchTab('login');return false;" href="#">Sign in</a><br>
        By continuing you agree to our <a href="#">Terms</a> and <a href="#">Privacy Policy</a></p>
    </div>
  </div>
</div>

<!-- SUCCESS POPUP -->
<div class="popup-overlay" id="successPopup">
  <div class="popup-box">
    <span class="popup-icon">&#x2705;</span>
    <div class="popup-title">Account Created!</div>
    <div class="popup-msg" id="popupMsg">Your account has been created successfully.<br>Please sign in with your credentials.</div>
    <button class="popup-btn" onclick="closePopup()">Sign In Now</button>
  </div>
</div>

<script>
var STATE = {};

function showAlert(type, msg) {
  var e = document.getElementById(type==='err'?'alertErr':'alertOk');
  var o = document.getElementById(type==='err'?'alertOk':'alertErr');
  e.textContent = msg; e.style.display = msg ? 'block' : 'none';
  o.style.display = 'none';
}
function showPopup(msg) {
  if (msg) document.getElementById('popupMsg').innerHTML = msg;
  document.getElementById('successPopup').classList.add('show');
}
function closePopup() {
  document.getElementById('successPopup').classList.remove('show');
  switchTab('login');
}
function switchTab(name) {
  ['Login','Register'].forEach(function(t) {
    var lower = t.toLowerCase();
    document.getElementById('tab'+t).classList.toggle('active', lower===name);
    document.getElementById('panel'+t).classList.toggle('active', lower===name);
  });
}
function switchMethod(m) {
  document.getElementById('mPwd').classList.toggle('active', m==='pwd');
  document.getElementById('mOtp').classList.toggle('active', m==='otp');
  document.getElementById('pwdFlow').style.display = m==='pwd' ? 'block' : 'none';
  document.getElementById('otpFlow').style.display = m==='otp' ? 'block' : 'none';
}
function showFP1() {
  document.getElementById('mainBlock').style.display = 'none';
  document.getElementById('fpBlock').style.display   = 'block';
  document.getElementById('fp1').style.display = 'block';
  document.getElementById('fp2').style.display = 'none';
  document.getElementById('fp3').style.display = 'none';
  showAlert('err',''); showAlert('ok','');
}
function showFP2From3() {
  document.getElementById('fp1').style.display = 'none';
  document.getElementById('fp2').style.display = 'block';
  document.getElementById('fp3').style.display = 'none';
}
function showMain() {
  document.getElementById('fpBlock').style.display   = 'none';
  document.getElementById('mainBlock').style.display = 'block';
  showAlert('err',''); showAlert('ok','');
}
// Bridge input order matches Python: _act, _email, _name, _pwd, _otp, _code, _newpwd
var BRIDGE_ORDER = ['_act','_email','_name','_pwd','_otp','_code','_newpwd'];

function getBridgeInputs() {
  var p = window.parent.document;
  // Find ONLY the off-screen hidden stTextInput wrappers we created as a bridge
  var all = p.querySelectorAll('[data-testid="stTextInput"]');
  var bridge = [];
  for (var i = 0; i < all.length; i++) {
    var wrapper = all[i];
    var style = p.defaultView.getComputedStyle(wrapper);
    // Our bridge inputs are moved off-screen to -9999px in CSS
    if (style.top === "-9999px" || style.left === "-9999px") {
      var inp = wrapper.querySelector('input');
      if (inp) bridge.push(inp);
    }
  }
  return bridge;
}

function setInputVal(inp, val) {
  var setter = Object.getOwnPropertyDescriptor(window.HTMLInputElement.prototype, 'value').set;
  setter.call(inp, val);
  inp.dispatchEvent(new Event('input', {bubbles: true}));
  inp.dispatchEvent(new Event('change', {bubbles: true}));
}

function post(action, fields) {
  try {
    var p = window.parent.document;
    var bridge = getBridgeInputs();

    // Map field names to bridge inputs purely by positional order
    function findInput(name) {
      var idx = BRIDGE_ORDER.indexOf(name);
      if (idx >= 0 && bridge[idx]) return bridge[idx];
      return null;
    }

    var actInp = findInput('_act');
    if (actInp) setInputVal(actInp, action);

    if (fields) {
      for (var k in fields) {
        var inp = findInput('_'+k);
        if (inp) setInputVal(inp, fields[k]);
      }
    }

    // Delay then click GO button
    setTimeout(function() {
      var btns = p.querySelectorAll('button');
      for (var j=0; j<btns.length; j++) {
        if (btns[j].textContent.trim() === 'GO') {
          btns[j].dispatchEvent(new MouseEvent('click', {bubbles: true}));
          return;
        }
      }
    }, 100);
  } catch(e) { console.error('post() error:', e); }
}
function setLoading(btn, text) {
  btn.disabled = true;
  btn.dataset.orig = btn.textContent;
  btn.textContent = text;
  btn.style.opacity = '0.7';
}
function clearLoading(btn) {
  if (btn && btn.dataset.orig) {
    btn.disabled = false;
    btn.textContent = btn.dataset.orig;
    btn.style.opacity = '1';
  }
}

function submitLogin() {
  var e=document.getElementById('loginEmail').value.trim();
  var p=document.getElementById('loginPwd').value;
  if (!e||!p){showAlert('err','Please fill in all fields.');return;}
  var btn=document.activeElement;
  if (!btn || btn.tagName!=='BUTTON'){btn=document.querySelector('#pwdFlow .btn');}
  if (btn){setLoading(btn,'Signing in...');}
  post('login',{email:e,pwd:p});
}
function submitRegister() {
  var n=document.getElementById('regName').value.trim();
  var e=document.getElementById('regEmail').value.trim();
  var p=document.getElementById('regPwd').value;
  var c=document.getElementById('regConfPwd').value;
  if (!n||!e||!p){showAlert('err','All fields are required.');return;}
  if (p.length<6){showAlert('err','Password must be at least 6 characters.');return;}
  if (p!==c){showAlert('err','Passwords do not match.');return;}
  var btn=document.activeElement;
  if (!btn || btn.tagName!=='BUTTON'){btn=document.querySelector('#panelRegister .btn');}
  if (btn){setLoading(btn,'Creating account...');}
  post('register',{name:n,email:e,pwd:p});
}
function submitOTPSend() {
  var e=document.getElementById('otpEmail').value.trim();
  if (!e){showAlert('err','Please enter your email.');return;}
  document.getElementById('otpEmailDisplay').textContent=e;
  var btn=document.activeElement;
  if (!btn || btn.tagName!=='BUTTON'){btn=document.querySelector('#otpStep1 .btn');}
  if (btn){setLoading(btn,'Sending code...');}
  post('otp_send',{email:e});
}
function backOTPStep1() {
  document.getElementById('otpStep1').style.display='block';
  document.getElementById('otpStep2').style.display='none';
}
function submitOTPVerify() {
  var c=document.getElementById('otpCode').value.trim();
  var e=document.getElementById('otpEmailDisplay').textContent;
  if (c.length!==6){showAlert('err','Code must be 6 digits.');return;}
  var btn=document.activeElement;
  if (!btn || btn.tagName!=='BUTTON'){btn=document.querySelector('#otpStep2 .btn');}
  if (btn){setLoading(btn,'Verifying...');}
  post('otp_verify',{email:e,code:c});
}
function submitFP1() {
  var e=document.getElementById('fpEmail').value.trim();
  if (!e){showAlert('err','Please enter your email.');return;}
  document.getElementById('fp2Email').textContent=e;
  var btn=document.activeElement;
  if (!btn || btn.tagName!=='BUTTON'){btn=document.querySelector('#fp1 .btn');}
  if (btn){setLoading(btn,'Sending...');}
  post('fp_send',{email:e});
}
function submitFP2() {
  var o=document.getElementById('fpOtp').value.trim();
  if (o.length!==6){showAlert('err','Code must be 6 digits.');return;}
  var btn=document.activeElement;
  if (!btn || btn.tagName!=='BUTTON'){btn=document.querySelector('#fp2 .btn');}
  if (btn){setLoading(btn,'Verifying...');}
  post('fp_verify',{otp:o});
}
function submitFP3() {
  var np=document.getElementById('fpNewPw').value;
  var cp=document.getElementById('fpConfPw').value;
  if (np.length<6){showAlert('err','Password must be at least 6 characters.');return;}
  if (np!==cp){showAlert('err','Passwords do not match.');return;}
  var btn=document.activeElement;
  if (!btn || btn.tagName!=='BUTTON'){btn=document.querySelector('#fp3 .btn');}
  if (btn){setLoading(btn,'Resetting...');}
  post('fp_reset',{newpwd:np});
}
</script>
</body>
</html>"""

    def _auth_card_with_state(err="", ok="", popup="", fp_step="", fp_email="", otp_sent=False, otp_email=""):
        state_js = (
            "STATE = {"
            f'"err":{repr(err)},"ok":{repr(ok)},"popup":{repr(popup)},'
            f'"fp_step":{repr(fp_step)},"fp_email":{repr(fp_email)},'
            f'"otp_sent":{"true" if otp_sent else "false"},"otp_email":{repr(otp_email)}'
            "};"
            "(function(){"
            "if(STATE.err){showAlert('err',STATE.err);}"
            "if(STATE.popup){showPopup(STATE.popup);}"
            "else if(STATE.ok){showAlert('ok',STATE.ok);}"
            "if(STATE.fp_step==='enter_otp'){"
            "document.getElementById('mainBlock').style.display='none';"
            "document.getElementById('fpBlock').style.display='block';"
            "document.getElementById('fp1').style.display='none';"
            "document.getElementById('fp2').style.display='block';"
            "document.getElementById('fp2Email').textContent=STATE.fp_email;}"
            "if(STATE.fp_step==='new_password'){"
            "document.getElementById('mainBlock').style.display='none';"
            "document.getElementById('fpBlock').style.display='block';"
            "document.getElementById('fp1').style.display='none';"
            "document.getElementById('fp2').style.display='none';"
            "document.getElementById('fp3').style.display='block';}"
            "if(STATE.otp_sent&&STATE.otp_email){"
            "switchMethod('otp');"
            "document.getElementById('otpStep1').style.display='none';"
            "document.getElementById('otpStep2').style.display='block';"
            "document.getElementById('otpEmailDisplay').textContent=STATE.otp_email;}"
            "})();"
        )
        return AUTH_CARD_HTML.replace(
            "var STATE = {};",
            "var STATE = {};\n" + state_js
        )

    # ── Bridge CSS: page reset + hide inputs visually but keep GO button clickable
    st.markdown("""<style>
    .block-container {
        padding: 0 !important;
        margin: 0 !important;
        max-width: 100% !important;
    }
    [data-testid="stToolbar"],
    [data-testid="stDecoration"],
    [data-testid="stToolbarActions"],
    .stAppToolbar, #MainMenu, footer,
    header[data-testid="stHeader"] { display: none !important; }
    .stVerticalBlock, [data-testid="stVerticalBlock"] { gap: 0 !important; }
    div[data-testid="stTextInput"] {
        position: fixed !important;
        top: -9999px !important;
        left: -9999px !important;
        width: 1px !important;
        height: 1px !important;
        overflow: hidden !important;
        opacity: 0 !important;
        margin: 0 !important;
        padding: 0 !important;
    }
    div[data-testid="stButton"] {
        position: fixed !important;
        top: 0 !important;
        left: 0 !important;
        width: 1px !important;
        height: 1px !important;
        overflow: hidden !important;
        opacity: 0 !important;
        margin: 0 !important;
        padding: 0 !important;
        z-index: 9999 !important;
    }
    div[data-testid="stButton"] button {
        width: 1px !important;
        height: 1px !important;
        min-height: 0 !important;
        padding: 0 !important;
        border: none !important;
        background: transparent !important;
    }
    </style>""", unsafe_allow_html=True)

    # ── Init auth session state keys ─────────────────────────────────────────
    for _k, _v in [
        ("auth_error", ""), ("auth_success", ""), ("auth_popup", ""),
        ("auth_otp_email", ""), ("fp_step", None),
        ("fp_email", ""), ("fp_otp_val", ""), ("otp_sent", False),
    ]:
        if _k not in st.session_state:
            st.session_state[_k] = _v

    # Hidden bridge inputs — invisible to user, used by card JS to trigger Python
    _act    = st.text_input("_act",    key="h_act",    label_visibility="collapsed")
    _email  = st.text_input("_email",  key="h_email",  label_visibility="collapsed")
    _name   = st.text_input("_name",   key="h_name",   label_visibility="collapsed")
    _pwd    = st.text_input("_pwd",    key="h_pwd",    label_visibility="collapsed", type="password")
    _otp    = st.text_input("_otp",    key="h_otp",    label_visibility="collapsed")
    _code   = st.text_input("_code",   key="h_code",   label_visibility="collapsed")
    _newpwd = st.text_input("_newpwd", key="h_newpwd", label_visibility="collapsed", type="password")
    _go     = st.button("GO", key="h_go")

    if _go and _act:
        act = _act.strip()

        if act == "login":
            try:
                r = requests.get("http://127.0.0.1:8000/login",
                                  params={"email": _email.strip(), "password": _pwd}, timeout=10)
                if r.status_code == 200:
                    data = r.json()
                    import uuid as _uuid_login
                    st.session_state.update({
                        "logged_in": True, "email": _email.strip(), "name": data["name"],
                        "chat_history": [], "chat_timestamps": [],
                        "current_session_id": str(_uuid_login.uuid4()),
                        "auth_error": "", "auth_success": "",
                    })
                    try:
                        sr = requests.get("http://127.0.0.1:8000/chat/sessions",
                                          params={"user_id": _email.strip()}, timeout=3).json()
                        sl = sr.get("sessions", [])
                        if sl:
                            st.session_state.chat_history       = sl[0].get("messages", [])
                            st.session_state.chat_timestamps    = sl[0].get("timestamps", [])
                            st.session_state.current_session_id = sl[0].get("session_id")
                    except Exception:
                        pass
                    st.rerun()
                elif r.status_code == 401:
                    st.session_state.auth_error = "Incorrect email or password."
                else:
                    st.session_state.auth_error = f"Login error ({r.status_code})."
            except Exception as ex:
                st.session_state.auth_error = f"Connection error: {ex}"

        elif act == "register":
            try:
                r = requests.post("http://127.0.0.1:8000/register",
                                   json={"name": _name.strip(), "email": _email.strip(), "password": _pwd},
                                   timeout=10)
                if r.status_code == 200:
                    st.session_state.auth_popup   = "Your account has been created successfully!<br>Please sign in with your credentials."
                    st.session_state.auth_success = ""
                    st.session_state.auth_error   = ""
                elif r.status_code == 409:
                    st.session_state.auth_error   = "Email already registered. Try signing in."
                    st.session_state.auth_success = ""
                else:
                    st.session_state.auth_error = f"Registration failed ({r.status_code})."
            except Exception as ex:
                st.session_state.auth_error = f"Connection error: {ex}"

        elif act == "otp_send":
            try:
                r = requests.post("http://127.0.0.1:8000/login_otp/send",
                                   params={"email": _email.strip()}, timeout=15)
                if r.status_code == 200:
                    st.session_state.otp_sent       = True
                    st.session_state.auth_otp_email = _email.strip()
                    st.session_state.auth_success   = f"Code sent to {_email.strip()}"
                    st.session_state.auth_error     = ""
                else:
                    st.session_state.auth_error = r.json().get("detail", "Failed to send code.")
            except Exception as ex:
                st.session_state.auth_error = f"Connection error: {ex}"

        elif act == "otp_verify":
            try:
                r = requests.post("http://127.0.0.1:8000/login_otp/verify",
                                   params={"email": _email.strip(), "otp": _code.strip()}, timeout=10)
                if r.status_code == 200:
                    data = r.json()
                    import uuid as _uuid_otp
                    st.session_state.update({
                        "logged_in": True, "email": _email.strip(), "name": data["name"],
                        "chat_history": [], "chat_timestamps": [],
                        "current_session_id": str(_uuid_otp.uuid4()),
                        "auth_error": "", "otp_sent": False,
                    })
                    try:
                        sr = requests.get("http://127.0.0.1:8000/chat/sessions",
                                          params={"user_id": _email.strip()}, timeout=3).json()
                        sl = sr.get("sessions", [])
                        if sl:
                            st.session_state.chat_history       = sl[0].get("messages", [])
                            st.session_state.chat_timestamps    = sl[0].get("timestamps", [])
                            st.session_state.current_session_id = sl[0].get("session_id")
                    except Exception:
                        pass
                    st.rerun()
                else:
                    st.session_state.auth_error = r.json().get("detail", "Invalid code.")
            except Exception as ex:
                st.session_state.auth_error = f"Connection error: {ex}"

        elif act == "fp_send":
            try:
                r = requests.post("http://127.0.0.1:8000/forgot_password/send_otp",
                                   params={"email": _email.strip()}, timeout=15)
                if r.status_code == 200:
                    st.session_state.fp_email     = _email.strip()
                    st.session_state.fp_step      = "enter_otp"
                    st.session_state.auth_success = f"Reset code sent to {_email.strip()}"
                    st.session_state.auth_error   = ""
                else:
                    st.session_state.auth_error = r.json().get("detail", "Failed.")
            except Exception as ex:
                st.session_state.auth_error = f"Connection error: {ex}"

        elif act == "fp_verify":
            try:
                r = requests.post("http://127.0.0.1:8000/forgot_password/verify_otp",
                                   params={"email": st.session_state.fp_email, "otp": _otp.strip()},
                                   timeout=10)
                if r.status_code == 200:
                    st.session_state.fp_otp_val = _otp.strip()
                    st.session_state.fp_step    = "new_password"
                    st.session_state.auth_error = ""
                else:
                    st.session_state.auth_error = r.json().get("detail", "Invalid code.")
            except Exception as ex:
                st.session_state.auth_error = f"Connection error: {ex}"

        elif act == "fp_reset":
            try:
                r = requests.post("http://127.0.0.1:8000/forgot_password/reset",
                                   json={"email": st.session_state.fp_email,
                                         "otp":   st.session_state.fp_otp_val,
                                         "new_password": _newpwd}, timeout=10)
                if r.status_code == 200:
                    st.session_state.fp_step      = None
                    st.session_state.fp_email     = ""
                    st.session_state.fp_otp_val   = ""
                    st.session_state.auth_success = "Password reset! You can now sign in."
                    st.session_state.auth_error   = ""
                else:
                    st.session_state.auth_error = r.json().get("detail", "Reset failed.")
            except Exception as ex:
                st.session_state.auth_error = f"Connection error: {ex}"

        st.rerun()

    # ── RENDER CARD ────────────────────────────────────────────────────────────
    card_html = _auth_card_with_state(
        err       = st.session_state.get("auth_error", ""),
        ok        = st.session_state.get("auth_success", ""),
        popup     = st.session_state.get("auth_popup", ""),
        fp_step   = st.session_state.get("fp_step") or "",
        fp_email  = st.session_state.get("fp_email", ""),
        otp_sent  = st.session_state.get("otp_sent", False),
        otp_email = st.session_state.get("auth_otp_email", ""),
    )
    st.session_state.auth_error   = ""
    st.session_state.auth_success = ""
    st.session_state.auth_popup   = ""
    components.html(card_html, height=800, scrolling=False)

else:
    # Handle tab redirect from chip buttons
    _goto_shadow = st.session_state.pop("goto_shadow", False)

    st.title(f"🧠 {st.session_state.name}'s Twin")
    tab_chat, tab_brain, tab_shadow, tab_mirror, tab_news, tab_analytics, tab_goals, tab_calendar = st.tabs([
        "💬 CONVERSATION", "🧠 BRAIN EXPLORER", "👾 SHADOW DEVELOPER",
        "🪞 STYLE MIRROR", "📰 TWIN NEWSROOM",
        "📊 ANALYTICS", "🎯 GOALS", "📅 CALENDAR"
    ])

    if _goto_shadow:
        st.info("👾 Head to the **SHADOW DEVELOPER** tab to review your code!")

    # ─── TAB: CONVERSATION ───────────────────────────────────────────────────
    with tab_chat:
        import datetime as _dt
        import uuid as _uuid

        # ── Auto-create session ID on first message ──────────────────────────
        if not st.session_state.get("current_session_id"):
            st.session_state.current_session_id = str(_uuid.uuid4())

        # ── Auto-save current session to backend whenever history changes ────
        def _save_session():
            hist = st.session_state.chat_history
            ts   = st.session_state.chat_timestamps
            if not hist:
                return
            # Derive title from first user message
            first_user = next((m["content"] for m in hist if m["role"] == "user"), "New Chat")
            title = first_user[:48] + ("…" if len(first_user) > 48 else "")
            try:
                requests.post("http://127.0.0.1:8000/chat/save", json={
                    "user_id":    st.session_state.email,
                    "session_id": st.session_state.current_session_id,
                    "messages":   hist,
                    "timestamps": ts,
                    "title":      title,
                }, timeout=3)
            except Exception:
                pass

        # ── TOP BAR: Chat History | New Chat ─────────────────────────────────
        tb1, tb2, tb3 = st.columns([0.22, 0.14, 0.64])
        with tb1:
            hist_label = "🕘 Hide History" if st.session_state.get("show_chat_history") else "🕘 Chat History"
            if st.button(hist_label, key="toggle_chat_history", use_container_width=True):
                st.session_state.show_chat_history = not st.session_state.get("show_chat_history", False)
                st.rerun()
        with tb2:
            if st.button("✏️ New Chat", key="new_chat_btn", use_container_width=True):
                _save_session()
                st.session_state.chat_history      = []
                st.session_state.chat_timestamps   = []
                st.session_state.current_session_id = str(_uuid.uuid4())
                st.session_state.show_chat_history  = False
                st.rerun()

        # ── SESSIONS PANEL (persistent history like ChatGPT/Gemini) ──────────
        if st.session_state.get("show_chat_history", False):
            try:
                sess_res = requests.get("http://127.0.0.1:8000/chat/sessions",
                                        params={"user_id": st.session_state.email}, timeout=4).json()
                sessions = sess_res.get("sessions", [])
            except Exception:
                sessions = []

            cur_msgs = st.session_state.chat_history
            cur_ts   = st.session_state.chat_timestamps

            # Merge in-memory history into sessions list for display
            total_pairs = sum(1 for m in cur_msgs if m["role"] == "user")
            total_sessions = len(sessions)

            st.markdown(f"""
            <div class="sess-panel">
                <div class="sess-header">
                    <span class="sess-title">💬 Chat History</span>
                    <span class="ch-count">{total_sessions} conversation{"s" if total_sessions != 1 else ""}</span>
                </div>
            </div>
            """, unsafe_allow_html=True)

            if not sessions and not cur_msgs:
                st.markdown('<div style="color:#475569;font-size:0.88rem;padding:12px 4px">🌙 No saved conversations yet.</div>', unsafe_allow_html=True)
            else:
                for sess in sessions:
                    sid     = sess.get("session_id", "")
                    s_title = sess.get("title", "Chat")
                    s_date  = sess.get("updated_at", "")[:10]
                    is_cur  = (sid == st.session_state.current_session_id)

                    s_col1, s_col2 = st.columns([0.82, 0.18])
                    with s_col1:
                        style = "sess-item sess-item-active" if is_cur else "sess-item"
                        st.markdown(f"""
                        <div class="{style}">
                            <div class="sess-item-title">{'🟢 ' if is_cur else '💬 '}{s_title}</div>
                            <div class="sess-item-meta">📅 {s_date}</div>
                        </div>""", unsafe_allow_html=True)
                    with s_col2:
                        if st.button("Load" if not is_cur else "View", key=f"load_sess_{sid}"):
                            _save_session()
                            try:
                                loaded = requests.get("http://127.0.0.1:8000/chat/load",
                                                      params={"user_id": st.session_state.email,
                                                              "session_id": sid}, timeout=4).json()
                                st.session_state.chat_history      = loaded.get("messages", [])
                                st.session_state.chat_timestamps   = loaded.get("timestamps", [])
                                st.session_state.current_session_id = sid
                                st.session_state.show_chat_history  = False
                            except Exception:
                                st.error("Could not load session.")
                            st.rerun()

                # Delete with expander
                with st.expander("🗑️ Delete a conversation"):
                    del_opts = {s.get("title","Chat")[:40]: s.get("session_id") for s in sessions}
                    del_choice = st.selectbox("Select", list(del_opts.keys()), key="del_sess_select")
                    if st.button("🗑️ Confirm Delete", key="del_sess_btn"):
                        del_sid = del_opts[del_choice]
                        try:
                            requests.delete(f"http://127.0.0.1:8000/chat/session/{del_sid}",
                                            params={"user_id": st.session_state.email}, timeout=4)
                        except Exception:
                            pass
                        if del_sid == st.session_state.current_session_id:
                            st.session_state.chat_history    = []
                            st.session_state.chat_timestamps = []
                            st.session_state.current_session_id = str(_uuid.uuid4())
                        st.session_state.show_chat_history = False
                        st.rerun()

            st.markdown("---")

        # ── LIVE CHAT ────────────────────────────────────────────────────────
        first_name = st.session_state.name.split()[0]

        # Beautiful welcome card + functional quick-action chips
        if not st.session_state.chat_history:
            st.markdown(f"""
            <div class="conv-welcome">
                <span class="conv-welcome-emoji">🧠</span>
                <h3>Hey <span>{first_name}</span>, your Twin is live</h3>
                <p>I know your style, your code, your people. Ask me anything.</p>
            </div>
            """, unsafe_allow_html=True)

            # Functional quick-action buttons styled as chips
            chip_c1, chip_c2, chip_c3, chip_c4, chip_c5 = st.columns(5)
            chip_prompt = None
            chip_goto_shadow = False

            with chip_c1:
                if st.button("👗 What to wear?", key="chip_wear", use_container_width=True):
                    chip_prompt = "Based on my personal style memories, what should I wear today? Also ask me if there's a specific occasion so you can tailor the suggestion."
            with chip_c2:
                if st.button("🎁 Gift idea", key="chip_gift", use_container_width=True):
                    chip_prompt = "Based on what you know about my relationships and interests, suggest a thoughtful gift idea. Ask me who the gift is for so you can personalise it."
            with chip_c3:
                if st.button("💻 Review code", key="chip_code", use_container_width=True):
                    chip_goto_shadow = True
            with chip_c4:
                if st.button("📰 Tech news", key="chip_news", use_container_width=True):
                    chip_prompt = "What are the most important and interesting tech news and AI developments trending right now? Give me a brief, engaging summary of the top 5 things I should know."
            with chip_c5:
                if st.button("🧬 What do you know?", key="chip_know", use_container_width=True):
                    chip_prompt = "Tell me everything you know about me based on your memories. Summarise my interests, style, work, and relationships in a personal and engaging way."

            # Navigate to shadow developer tab
            if chip_goto_shadow:
                st.session_state["goto_shadow"] = True
                st.rerun()

            # Fire chip as a prompt
            if chip_prompt:
                st.session_state["chip_inject"] = chip_prompt
                st.rerun()

        # Handle chip-injected prompt (after rerun)
        if st.session_state.get("chip_inject"):
            chip_prompt = st.session_state.pop("chip_inject")
            now_str = _dt.datetime.now().strftime("%d %b %Y • %I:%M %p")
            st.session_state.chat_history.append({"role": "user", "content": chip_prompt})
            st.session_state.chat_timestamps.append(now_str)
            with st.chat_message("user"):
                st.write(chip_prompt)
            with st.chat_message("assistant"):
                with st.spinner("✨ Twin is thinking…"):
                    try:
                        res = requests.get("http://127.0.0.1:8000/ask",
                                           params={"user_id": st.session_state.email,
                                                   "question": chip_prompt, "mood": twin_mood})
                        answer = res.json()["answer"]
                        st.write(answer)
                        reply_ts = _dt.datetime.now().strftime("%d %b %Y • %I:%M %p")
                        st.session_state.chat_history.append({"role": "assistant", "content": answer})
                        st.session_state.chat_timestamps.append(reply_ts)
                        st.session_state.last_answer = answer
                        _save_session()
                        if st.session_state.get("voice_enabled", True):
                            speak_text(answer)
                    except Exception as ex:
                        st.error(f"Error: {str(ex)}")
            st.rerun()

        # Live messages
        for message in st.session_state.chat_history:
            with st.chat_message(message["role"]):
                st.write(message["content"])

        # ── COMPACT ACTION ROW ──────────────────────────────────────────────
        a1, a2, a3 = st.columns([0.13, 0.13, 0.74])
        with a1:
            img_on = st.toggle("📎 Photo", key="show_img_upload",
                               value=st.session_state.get("show_img_upload", False))
        with a2:
            voice_on = st.toggle("🎤 Voice", key="show_voice_input",
                                 value=st.session_state.get("show_voice_input", False))
        with a3:
            if img_on or voice_on:
                active = []
                if img_on:   active.append("📎 image upload active")
                if voice_on: active.append("🎤 voice input active")
                st.markdown(f"<p style='color:#38bdf8;font-size:0.78rem;margin-top:9px;font-weight:600'>{'  ·  '.join(active)}</p>", unsafe_allow_html=True)
            else:
                st.markdown("<p style='color:#334155;font-size:0.75rem;margin-top:9px'>📎 or 🎤 to attach</p>", unsafe_allow_html=True)

        uploaded_images = None
        voice_prompt    = None

        if img_on:
            st.markdown('<div class="conv-upload-slim"><span class="conv-upload-slim-label">📎 ATTACH IMAGES · JPG / PNG · UP TO 10</span>', unsafe_allow_html=True)
            uploaded_images = st.file_uploader(
                "", type=["jpg", "jpeg", "png"],
                accept_multiple_files=True,
                label_visibility="collapsed",
            )
            st.markdown('</div>', unsafe_allow_html=True)

        if voice_on:
            voice_key   = f"voice_input_{st.session_state.get('voice_input_key', 0)}"
            voice_prompt = speech_to_text(
                language="en",
                start_prompt="🎤  Tap & speak",
                stop_prompt="🛑  Stop",
                key=voice_key,
            )

        text_prompt = st.chat_input("Ask your Twin anything…")
        prompt = text_prompt or voice_prompt

        if st.session_state.get("suppress_next_prompt", False):
            st.session_state["suppress_next_prompt"] = False
            prompt = None

        if prompt:
            emotion      = st.session_state.get("detected_emotion", "neutral")
            webcam_active = st.session_state.get("webcam_mood_enabled", False)
            tone_desc, emotion_opener = EMOTION_TONE.get(emotion, EMOTION_TONE["neutral"])
            mood_instruction = ""
            if webcam_active and emotion != "neutral":
                mood_instruction = (
                    f"The user appears to be feeling {emotion} right now. Adopt a {tone_desc} tone. "
                    f"Start your reply with: '{emotion_opener}' then answer their question."
                )
            now_str = _dt.datetime.now().strftime("%d %b %Y • %I:%M %p")
            st.session_state.chat_history.append({"role": "user", "content": prompt})
            st.session_state.chat_timestamps.append(now_str)
            with st.chat_message("user"):
                st.write(prompt)
            with st.chat_message("assistant"):
                with st.spinner("✨ Twin is thinking…"):
                    try:
                        _lang = st.session_state.get("language", "English")
                        _lang_instr = f"\n\n[LANGUAGE: Always respond in {_lang}.]" if _lang != "English" else ""
                        augmented_question = (f"[MOOD CONTEXT: {mood_instruction}]\n\nUser question: {prompt}{_lang_instr}" if mood_instruction else f"{prompt}{_lang_instr}")
                        if uploaded_images:
                            files = [("files", (img.name, img.getvalue(), img.type)) for img in uploaded_images[:10]]
                            res = requests.post("http://127.0.0.1:8000/analyze_image",
                                                params={"user_id": st.session_state.email, "question": augmented_question, "mood": twin_mood},
                                                files=files)
                        else:
                            res = requests.get("http://127.0.0.1:8000/ask",
                                               params={"user_id": st.session_state.email, "question": augmented_question, "mood": twin_mood})
                        answer = res.json()["answer"]
                        st.write(answer)
                        reply_ts = _dt.datetime.now().strftime("%d %b %Y • %I:%M %p")
                        st.session_state.chat_history.append({"role": "assistant", "content": answer})
                        st.session_state.chat_timestamps.append(reply_ts)
                        st.session_state.last_answer = answer
                        _save_session()
                        if st.session_state.get("voice_enabled", True):
                            speak_text(answer)
                        st.session_state["voice_input_key"] = st.session_state.get("voice_input_key", 0) + 1
                    except Exception as ex:
                        st.error(f"Error: {str(ex)}")

    # ─── TAB: BRAIN EXPLORER ────────────────────────────────────────────────
    with tab_brain:
        col_left, col_right = st.columns([0.4, 0.6])
        with col_left:
            st.subheader("🧬 Training")
            fact = st.text_area("Update Twin Memory:", height=150)
            if st.button("Integrate Memory"):
                requests.post(f"http://127.0.0.1:8000/train?user_id={st.session_state.email}&details={fact}")
                st.success("Trained!")
        with col_right:
            st.subheader("🧠 Memory List")
            try:
                import datetime
                m_res = requests.get(f"http://127.0.0.1:8000/memories?user_id={st.session_state.email}").json()
                memories = m_res.get("memories", [])
                ids      = m_res.get("ids", [])
                # Category detection helper
                def detect_category(text):
                    t = text.lower()
                    if any(k in t for k in ["[coding style", "code", "python", "javascript", "function", "def ", "class ", "import "]):
                        return ("💻", "Code Style")
                    if any(k in t for k in ["[personal style]", "wear", "outfit", "fashion", "hoodie", "jeans", "colour"]):
                        return ("👗", "Style")
                    if any(k in t for k in ["like", "love", "enjoy", "play", "hobby", "sport", "music", "game"]):
                        return ("❤️", "Interest")
                    if any(k in t for k in ["work", "job", "company", "project", "team", "office", "client"]):
                        return ("💼", "Work")
                    if any(k in t for k in ["friend", "family", "sister", "brother", "mom", "dad", "colleague"]):
                        return ("👥", "People")
                    return ("🧠", "General")

                if memories:
                    st.markdown(f'<span class="memory-count-badge">🗂️ {len(memories)} memories stored</span>', unsafe_allow_html=True)
                    # Assign a pseudo-timestamp: newest first (index 0 = most recent)
                    now = datetime.datetime.now()
                    for i, (text, mid) in enumerate(zip(memories, ids)):
                        # Spread timestamps: most recent = now, older ones spaced back
                        delta_minutes = i * 7  # each older memory ~7 min apart
                        ts = now - datetime.timedelta(minutes=delta_minutes)
                        date_str = ts.strftime("%d %b %Y")
                        time_str = ts.strftime("%I:%M %p")
                        icon, cat = detect_category(text)
                        # Clean display text (strip internal tags)
                        display_text = text
                        for tag in ["[CODING STYLE EXAMPLE]", "[PERSONAL STYLE]"]:
                            display_text = display_text.replace(tag, "").strip()
                        if len(display_text) > 180:
                            display_text = display_text[:180] + "…"

                        c1, c2 = st.columns([0.88, 0.12])
                        with c1:
                            st.markdown(f"""
                            <div class="memory-card">
                                <div class="memory-card-text">{display_text}</div>
                                <div class="memory-card-meta">
                                    <span class="memory-badge">🕐 {time_str}</span>
                                    <span class="memory-badge">📅 {date_str}</span>
                                    <span class="memory-badge-cat">{icon} {cat}</span>
                                </div>
                            </div>
                            """, unsafe_allow_html=True)
                        with c2:
                            st.markdown("<div style='padding-top:10px'>", unsafe_allow_html=True)
                            if st.button("🗑️", key=f"del_{i}"):
                                requests.delete(f"http://127.0.0.1:8000/memories/{mid}")
                                st.rerun()
                            st.markdown("</div>", unsafe_allow_html=True)
                else:
                    st.info("No memories yet. Add your first memory using the Training panel on the left!")
            except:
                pass

    # ─── TAB: SHADOW DEVELOPER (ENHANCED) ───────────────────────────────────
    with tab_shadow:
        st.markdown("""
        <div class="shadow-header">
            <h3>👾 Shadow Developer Mode — Enhanced</h3>
            <p>Train your twin with your coding style, then debug with syntax checking, code execution, diff view, and git repo context.</p>
        </div>
        """, unsafe_allow_html=True)

        shadow_col1, shadow_col2 = st.columns([0.45, 0.55])

        # ── LEFT: STYLE TRAINING + REPO EXPLORER ────────────────────────────
        with shadow_col1:
            st.subheader("🧬 Teach Your Coding Style")
            st.caption("Paste examples of your own code so the twin learns your patterns.")
            style_snippet = st.text_area(
                "Paste a code snippet that represents your style:", height=180,
                placeholder="def fetch_user(user_id):\n    try:\n        result = db.find({'_id': user_id})\n        return result\n    except Exception as e:\n        print(f'Error: {e}')\n        return None",
                key="style_snippet",
            )
            style_note = st.text_input(
                "Describe this style (optional):",
                placeholder="e.g. I always use try/except, snake_case, short variable names",
                key="style_note",
            )
            if st.button("🧠 Train Coding Style", key="train_style"):
                if style_snippet.strip():
                    note = style_note.strip() or "general coding style"
                    training_text = f"[CODING STYLE EXAMPLE] {note}:\n```\n{style_snippet}\n```"
                    with st.spinner("Learning your coding style..."):
                        requests.post("http://127.0.0.1:8000/train",
                                      params={"user_id": st.session_state.email, "details": training_text})
                    st.success("✅ Coding style learned!")
                else:
                    st.warning("Please paste a code snippet first.")

            st.markdown("---")
            st.caption("📚 Learned coding styles:")
            try:
                m_res = requests.get(f"http://127.0.0.1:8000/memories?user_id={st.session_state.email}").json()
                style_memories = [(m, mid) for m, mid in zip(m_res["memories"], m_res["ids"]) if "[CODING STYLE EXAMPLE]" in m]
                if style_memories:
                    for mem, mid in style_memories:
                        preview = mem.replace("[CODING STYLE EXAMPLE]", "").strip()[:120]
                        c1, c2 = st.columns([0.88, 0.12])
                        with c1:
                            st.markdown(f'<div class="code-style-card">🔖 {preview}...</div>', unsafe_allow_html=True)
                        with c2:
                            if st.button("🗑️", key=f"del_style_{mid}"):
                                requests.delete(f"http://127.0.0.1:8000/memories/{mid}")
                                st.rerun()
                else:
                    st.caption("No coding styles trained yet.")
            except:
                pass

            # ── GIT REPO EXPLORER ────────────────────────────────────────────
            st.markdown("---")
            st.subheader("📁 Git Repo Explorer")
            st.caption("Point your twin to a local repo — it reads all code files as context for debugging.")
            repo_path_input = st.text_input(
                "Local repo path:", placeholder="/home/user/my-project  or  ~/projects/app",
                key="repo_path_input",
            )
            repo_ext_filter = st.text_input(
                "File extensions (optional):", placeholder=".py,.js,.ts  (leave blank for all code files)",
                key="repo_ext_filter",
            )
            if st.button("🔍 Browse Repo", key="browse_repo"):
                if repo_path_input.strip():
                    with st.spinner("Reading repo files..."):
                        params = {"repo_path": repo_path_input.strip(), "max_files": 25}
                        if repo_ext_filter.strip():
                            params["extensions"] = repo_ext_filter.strip()
                        try:
                            repo_res = requests.get("http://127.0.0.1:8000/repo_files", params=params)
                            repo_data = repo_res.json()
                            st.session_state["last_repo_data"] = repo_data
                            git_badge = "✅ Git repo" if repo_data.get("is_git_repo") else "📂 Folder"
                            trunc_badge = " (truncated)" if repo_data.get("truncated") else ""
                            st.success(f"{git_badge} — {repo_data['total_files']} files found{trunc_badge}")
                        except Exception as ex:
                            st.error(f"Repo browse error: {ex}")
                else:
                    st.warning("Enter a repo path first.")

            if st.session_state.get("last_repo_data"):
                rd = st.session_state["last_repo_data"]
                with st.expander(f"📋 {rd['total_files']} files in repo", expanded=False):
                    for fp, content_preview in rd.get("files", {}).items():
                        st.markdown(f'<div class="repo-card"><b>{fp}</b><br><code>{content_preview[:200]}{"..." if len(content_preview) > 200 else ""}</code></div>', unsafe_allow_html=True)
                    if rd.get("errors"):
                        for err in rd["errors"]:
                            st.warning(f"⚠️ {err}")

        # ── RIGHT: DEBUG PANEL ───────────────────────────────────────────────
        with shadow_col2:
            st.subheader("🐛 Debug With Your Twin")
            st.caption("Paste your code — get syntax checks, AI analysis, execution, and a diff.")

            language = st.selectbox(
                "Language:",
                ["Python", "JavaScript", "TypeScript", "Java", "C++", "C", "Go", "Rust", "Bash", "Other"],
                key="debug_language",
            )
            debug_mode = st.radio(
                "What do you need?",
                ["🐛 Find & Fix Bugs", "🔍 Code Review", "⚡ Optimize Code", "💬 Explain This Code"],
                key="debug_mode", horizontal=True,
            )
            buggy_code = st.text_area(
                "Paste your code here:", height=220,
                placeholder="def calculate_total(items):\n    total = 0\n    for i in items\n        total += i['price']\n    return totl",
                key="buggy_code",
            )
            extra_context = st.text_input(
                "What's the problem? (optional):",
                placeholder="e.g. Getting KeyError on line 5, or function returns None unexpectedly",
                key="extra_context",
            )

            # ── Execution toggles ────────────────────────────────────────────
            exec_col1, exec_col2 = st.columns(2)
            with exec_col1:
                run_original = st.checkbox(
                    "▶️ Run original code",
                    value=False, key="run_original",
                    help="Execute the code as-is before AI analysis (Python/JS/Bash only).",
                )
            with exec_col2:
                run_fixed = st.checkbox(
                    "▶️ Run fixed code",
                    value=False, key="run_fixed",
                    help="Execute the AI-fixed code after analysis (Python/JS/Bash only).",
                )

            # Use repo path from the left panel if available
            use_repo = st.checkbox(
                "📁 Include repo context",
                value=False, key="use_repo_ctx",
                help="Include files from the repo you browsed on the left as extra context.",
            )
            repo_path_for_debug = repo_path_input if use_repo and repo_path_input.strip() else ""

            if st.button("👾 Activate Shadow Developer", key="run_shadow", type="primary"):
                if buggy_code.strip():
                    mode_label = debug_mode.split(" ", 1)[1]

                    with st.spinner("👾 Shadow Developer analysing your code..."):
                        try:
                            payload = {
                                "user_id": st.session_state.email,
                                "code": buggy_code,
                                "language": language,
                                "mode": mode_label,
                                "mood": twin_mood,
                                "extra_context": extra_context or "",
                                "run_code": run_original,
                                "run_fixed": run_fixed,
                                "repo_path": repo_path_for_debug,
                            }
                            res = requests.post("http://127.0.0.1:8000/debug_code", json=payload, timeout=60)
                            data = res.json()

                            # ── SYNTAX CHECK RESULTS ─────────────────────────
                            syntax = data.get("syntax_check", {})
                            if syntax.get("errors") or syntax.get("warnings"):
                                st.markdown("### 🔍 Pre-Analysis Syntax Check")
                                for err in syntax.get("errors", []):
                                    st.markdown(f'<div class="syntax-error-card">❌ {err}</div>', unsafe_allow_html=True)
                                for warn in syntax.get("warnings", []):
                                    st.markdown(f'<div class="syntax-warn-card">⚠️ {warn}</div>', unsafe_allow_html=True)
                            else:
                                st.success("✅ Pre-analysis syntax check passed.")

                            # ── ORIGINAL EXECUTION RESULTS ───────────────────
                            eo = data.get("execution_original", {})
                            if eo.get("ran"):
                                st.markdown("### ▶️ Original Code Execution")
                                exit_icon = "✅" if eo["exit_code"] == 0 else "❌"
                                st.markdown(
                                    f'<div class="exec-card">'
                                    f'{exit_icon} Exit code: <b>{eo["exit_code"]}</b><br><br>'
                                    f'<b>STDOUT:</b><pre>{eo["stdout"] or "(empty)"}</pre>'
                                    f'<b>STDERR:</b><pre>{eo["stderr"] or "(none)"}</pre>'
                                    f'</div>',
                                    unsafe_allow_html=True,
                                )
                            elif run_original and eo.get("reason"):
                                st.info(f"ℹ️ Execution skipped: {eo['reason']}")

                            # ── REPO CONTEXT BADGE ───────────────────────────
                            if data.get("repo_context_used"):
                                st.info(f"📁 Repo context included: {data.get('repo_files_read', 0)} files read.")

                            # ── AI ANALYSIS ──────────────────────────────────
                            st.markdown("### 🤖 AI Analysis")
                            st.markdown('<div class="debug-result">', unsafe_allow_html=True)
                            st.markdown(data.get("ai_analysis", "No response."))
                            st.markdown('</div>', unsafe_allow_html=True)

                            # ── DIFF VIEW ────────────────────────────────────
                            diff_text = data.get("diff", "")
                            fixed_code = data.get("fixed_code", "")
                            if fixed_code and "No changes" not in diff_text:
                                st.markdown("### 📊 What Changed — Diff View")
                                diff_html = render_diff_html(diff_text)
                                st.markdown(
                                    f'<div class="diff-card">{diff_html}</div>',
                                    unsafe_allow_html=True,
                                )
                                # Copy-ready fixed code
                                with st.expander("📋 Copy Fixed Code", expanded=False):
                                    st.code(fixed_code, language=language.lower())
                            else:
                                if diff_text:
                                    st.caption(f"ℹ️ {diff_text}")

                            # ── FIXED CODE EXECUTION RESULTS ─────────────────
                            ef = data.get("execution_fixed", {})
                            if ef.get("ran"):
                                st.markdown("### ▶️ Fixed Code Execution")
                                exit_icon = "✅" if ef["exit_code"] == 0 else "❌"
                                st.markdown(
                                    f'<div class="exec-card">'
                                    f'{exit_icon} Exit code: <b>{ef["exit_code"]}</b><br><br>'
                                    f'<b>STDOUT:</b><pre>{ef["stdout"] or "(empty)"}</pre>'
                                    f'<b>STDERR:</b><pre>{ef["stderr"] or "(none)"}</pre>'
                                    f'</div>',
                                    unsafe_allow_html=True,
                                )
                            elif run_fixed and ef.get("reason"):
                                st.info(f"ℹ️ Fixed execution skipped: {ef['reason']}")

                            # ── SYNC TO CHAT HISTORY ──────────────────────────
                            st.session_state.chat_history.append({
                                "role": "user",
                                "content": f"👾 **Shadow Dev** [{mode_label} | {language}]:\n```\n{buggy_code[:300]}{'...' if len(buggy_code) > 300 else ''}\n```",
                            })
                            st.session_state.chat_history.append({
                                "role": "assistant",
                                "content": data.get("ai_analysis", ""),
                            })

                            if st.session_state.get("voice_enabled", True):
                                speak_text(data.get("ai_analysis", ""))

                        except Exception as ex:
                            st.error(f"Shadow Developer Error: {str(ex)}")
                else:
                    st.warning("Please paste some code first.")

    # ─── TAB: STYLE MIRROR ──────────────────────────────────────────────────
    with tab_mirror:
        st.markdown("""
        <div class="mirror-header">
            <h3>🪞 Style Mirror — Your AI Fashion Critic</h3>
            <p>Upload a photo of your outfit. Your Twin grades it against your personal style profile
            and acts as your 24/7 stylist who actually knows your wardrobe.</p>
        </div>
        """, unsafe_allow_html=True)

        mirror_col1, mirror_col2 = st.columns([0.45, 0.55])

        with mirror_col1:
            st.subheader("📸 Upload Your Outfit")
            outfit_images = st.file_uploader(
                "Upload 1–3 outfit photos", type=["jpg", "jpeg", "png", "webp"],
                accept_multiple_files=True, key="outfit_uploader",
            )
            occasion = st.selectbox(
                "🎯 What's the occasion?",
                ["casual", "office / work", "date night", "party / nightout",
                 "gym / workout", "formal / wedding", "beach / vacation", "college / campus", "festival"],
                key="mirror_occasion",
            )
            st.markdown("---")
            st.subheader("🧬 Teach Your Style (optional)")
            st.caption("Train your twin with style notes so grades become more personalised over time.")
            style_fact = st.text_area(
                "Add a style preference:", height=100,
                placeholder="e.g. I love oversized black hoodies, slim-fit jeans and white sneakers. I avoid bright colours.",
                key="mirror_style_fact",
            )
            if st.button("💾 Save Style Preference", key="save_style_pref"):
                if style_fact.strip():
                    with st.spinner("Saving style preference..."):
                        requests.post("http://127.0.0.1:8000/train",
                                      params={"user_id": st.session_state.email, "details": f"[PERSONAL STYLE] {style_fact.strip()}"})
                    st.success("✅ Style preference saved!")
                else:
                    st.warning("Please enter a style preference first.")

            st.markdown("---")
            st.caption("📋 Your saved style profile:")
            try:
                m_res = requests.get(f"http://127.0.0.1:8000/memories?user_id={st.session_state.email}").json()
                style_prefs = [(m, mid) for m, mid in zip(m_res["memories"], m_res["ids"]) if "[PERSONAL STYLE]" in m]
                if style_prefs:
                    for mem, mid in style_prefs:
                        preview = mem.replace("[PERSONAL STYLE]", "").strip()[:130]
                        c1, c2 = st.columns([0.88, 0.12])
                        with c1:
                            st.markdown(f'<div class="style-tip-card">👗 {preview}{"..." if len(preview) >= 130 else ""}</div>', unsafe_allow_html=True)
                        with c2:
                            if st.button("🗑️", key=f"del_style_pref_{mid}"):
                                requests.delete(f"http://127.0.0.1:8000/memories/{mid}")
                                st.rerun()
                else:
                    st.caption("No style profile yet — add some preferences above!")
            except:
                pass

        with mirror_col2:
            st.subheader("🎨 Fashion Grade")
            if outfit_images:
                preview_cols = st.columns(min(len(outfit_images), 3))
                for idx, img in enumerate(outfit_images[:3]):
                    with preview_cols[idx]:
                        st.image(img, use_container_width=True, caption=f"Photo {idx + 1}")

            run_mirror = st.button("🪞 Grade My Outfit", key="run_style_mirror", type="primary", disabled=not outfit_images)
            if not outfit_images:
                st.info("👆 Upload an outfit photo on the left to get started.")

            if run_mirror and outfit_images:
                with st.spinner("🪞 Your Twin is analysing your outfit..."):
                    try:
                        files = [("files", (img.name, img.getvalue(), img.type)) for img in outfit_images[:3]]
                        res = requests.post("http://127.0.0.1:8000/style_mirror",
                                            params={"user_id": st.session_state.email, "mood": twin_mood, "occasion": occasion},
                                            files=files)
                        answer = res.json().get("answer", "No response from Style Mirror.")
                        import re
                        score_match = re.search(r"(\d+(?:\.\d+)?)/10", answer)
                        if score_match:
                            st.markdown(f'<div style="text-align:center"><span class="score-badge">⭐ {score_match.group(0)}</span></div>', unsafe_allow_html=True)

                        st.markdown('<div class="mirror-result">', unsafe_allow_html=True)
                        st.markdown(answer)
                        st.markdown('</div>', unsafe_allow_html=True)

                        if "style_mirror_history" not in st.session_state:
                            st.session_state.style_mirror_history = []
                        st.session_state.style_mirror_history.append({
                            "occasion": occasion,
                            "score": score_match.group(0) if score_match else "?/10",
                            "report": answer,
                        })
                        st.session_state.chat_history.append({"role": "user", "content": f"🪞 **Style Mirror** [{occasion}]: [outfit photo(s)]"})
                        st.session_state.chat_history.append({"role": "assistant", "content": answer})
                        if st.session_state.get("voice_enabled", True):
                            speak_text(answer)
                    except Exception as ex:
                        st.error(f"Style Mirror Error: {str(ex)}")

            history = st.session_state.get("style_mirror_history", [])
            if len(history) > 1:
                st.markdown("---")
                st.subheader("📊 This Session's Grades")
                for h in reversed(history[:-1]):
                    st.markdown(f'<div class="style-tip-card">🎯 <b>{h["occasion"].capitalize()}</b> — Score: <b>{h["score"]}</b></div>', unsafe_allow_html=True)

    # ─── TAB: TWIN NEWSROOM ─────────────────────────────────────────────────
    with tab_news:
        st.markdown("""
        <div class="newsroom-header">
            <h3>📰 Twin Newsroom — Your Personalised Morning Briefing</h3>
            <p>Your Twin scans live news about your tech stack, location, and interests —
            then delivers it in your voice and mood. Hit the button every morning.</p>
        </div>
        """, unsafe_allow_html=True)

        news_col1, news_col2 = st.columns([0.38, 0.62])

        with news_col1:
            st.subheader("⚙️ Briefing Settings")

            st.caption("📍 Locations to track")
            location_input = st.text_input(
                "Cities / Regions (comma-separated):",
                value=st.session_state.get("newsroom_locations", "Delhi, India"),
                placeholder="Delhi, Patna, India",
                key="newsroom_loc_input",
            )
            st.session_state["newsroom_locations"] = location_input

            st.caption("🔖 Extra topics to follow (optional)")
            topics_input = st.text_input(
                "Topics (comma-separated):",
                value=st.session_state.get("newsroom_topics", ""),
                placeholder="startups, open source, cloud computing",
                key="newsroom_topics_input",
            )
            st.session_state["newsroom_topics"] = topics_input

            st.markdown("---")

            news_mood = st.radio(
                "📣 Briefing Tone",
                ["Professional", "Natural", "Sarcastic"],
                index=["Professional", "Natural", "Sarcastic"].index(
                    st.session_state.get("newsroom_mood", "Natural")
                ),
                key="newsroom_mood_radio",
                horizontal=True,
            )
            st.session_state["newsroom_mood"] = news_mood

            st.markdown("---")
            st.caption("🧠 Tech stack is auto-detected from your Twin's memory. "
                       "Train more memories in Brain Explorer to improve relevance.")

            if st.session_state.get("last_briefing_stack"):
                st.caption("Last detected stack:")
                stack_html = "".join(
                    f'<span class="tech-tag">{t}</span>'
                    for t in st.session_state["last_briefing_stack"]
                )
                st.markdown(stack_html, unsafe_allow_html=True)

            st.markdown("---")

            run_briefing = st.button(
                "☀️ Get My Morning Report",
                key="run_morning_briefing",
                type="primary",
                use_container_width=True,
            )

            if st.session_state.get("last_briefing_text"):
                st.markdown("---")
                st.caption("📋 Briefing history this session:")
                history_count = len(st.session_state.get("newsroom_history", []))
                st.markdown(
                    f'<span class="news-meta-badge">🗞️ {history_count} briefing(s) generated</span>',
                    unsafe_allow_html=True,
                )

        with news_col2:
            st.subheader("🗞️ Your Briefing")

            if st.session_state.get("last_briefing_text") and not run_briefing:
                last = st.session_state["last_briefing_text"]
                st.markdown('<div class="briefing-card">', unsafe_allow_html=True)
                st.markdown(last)
                st.markdown("</div>", unsafe_allow_html=True)

                meta_html = ""
                if st.session_state.get("last_briefing_articles"):
                    meta_html += f'<span class="news-meta-badge">📡 {st.session_state["last_briefing_articles"]} articles scanned</span>'
                if st.session_state.get("last_briefing_mood"):
                    meta_html += f'<span class="news-meta-badge">🎭 {st.session_state["last_briefing_mood"]} tone</span>'
                if meta_html:
                    st.markdown(meta_html, unsafe_allow_html=True)

                if st.session_state.get("voice_enabled", True):
                    if st.button("🔊 Read Briefing Aloud", key="read_briefing"):
                        speak_text(st.session_state["last_briefing_text"])
            else:
                if not run_briefing:
                    st.info("👈 Configure your settings and hit **☀️ Get My Morning Report** to start.")

            if run_briefing:
                locations = [l.strip() for l in location_input.split(",") if l.strip()] or ["India"]
                topics    = [t.strip() for t in topics_input.split(",") if t.strip()]

                with st.spinner("📡 Scanning live news across your world..."):
                    try:
                        payload = {
                            "user_id": st.session_state.email,
                            "mood": news_mood,
                            "locations": locations,
                            "extra_topics": topics,
                        }
                        res = requests.post(
                            "http://127.0.0.1:8000/morning_briefing",
                            json=payload,
                            timeout=60,
                        )
                        data = res.json()
                        briefing_text = data.get("briefing", "No briefing returned.")
                        articles_found = data.get("articles_found", 0)
                        tech_stack = data.get("tech_stack_detected", [])

                        st.session_state["last_briefing_text"]     = briefing_text
                        st.session_state["last_briefing_articles"] = articles_found
                        st.session_state["last_briefing_mood"]     = news_mood
                        st.session_state["last_briefing_stack"]    = tech_stack

                        if "newsroom_history" not in st.session_state:
                            st.session_state["newsroom_history"] = []
                        st.session_state["newsroom_history"].append({
                            "mood": news_mood,
                            "articles": articles_found,
                            "stack": tech_stack,
                            "preview": briefing_text[:120] + "...",
                        })

                        meta_html = f'<span class="news-meta-badge">📡 {articles_found} articles scanned</span>'
                        meta_html += f'<span class="news-meta-badge">🎭 {news_mood} tone</span>'
                        if tech_stack:
                            meta_html += " ".join(f'<span class="tech-tag">{t}</span>' for t in tech_stack)
                        st.markdown(meta_html, unsafe_allow_html=True)
                        st.markdown("")

                        st.markdown('<div class="briefing-card">', unsafe_allow_html=True)
                        st.markdown(briefing_text)
                        st.markdown("</div>", unsafe_allow_html=True)

                        st.session_state.chat_history.append({
                            "role": "user",
                            "content": f"☀️ **Morning Briefing** [{news_mood} | {', '.join(locations)}]",
                        })
                        st.session_state.chat_history.append({
                            "role": "assistant",
                            "content": briefing_text,
                        })

                        if st.session_state.get("voice_enabled", True):
                            speak_text(briefing_text)

                    except requests.exceptions.Timeout:
                        st.error("⏰ Request timed out. The news fetch can take up to 30s — try again.")
                    except Exception as ex:
                        st.error(f"Newsroom Error: {str(ex)}")


    # ─── TAB: ANALYTICS DASHBOARD ───────────────────────────────────────────
    with tab_analytics:
        import plotly.express as px
        import plotly.graph_objects as go
        import pandas as pd

        st.markdown("""
        <div style='background:linear-gradient(135deg,rgba(56,189,248,0.1),rgba(99,102,241,0.08));
        border:1px solid rgba(56,189,248,0.2);border-radius:16px;padding:18px 24px;margin-bottom:20px'>
        <h3 style='color:#38bdf8;margin:0 0 4px 0'>📊 Twin Analytics</h3>
        <p style='color:#64748b;margin:0;font-size:0.88rem'>Insights about your memories, chat patterns and knowledge base.</p>
        </div>""", unsafe_allow_html=True)

        try:
            ana_res = requests.get(f"http://127.0.0.1:8000/analytics?user_id={st.session_state.email}").json()
            counts  = ana_res.get("counts", {})

            sess_res = requests.get("http://127.0.0.1:8000/chat/sessions",
                                    params={"user_id": st.session_state.email}, timeout=4).json()
            sessions = sess_res.get("sessions", [])
            total_msgs = sum(len(s.get("messages", [])) for s in sessions)
            total_user = sum(sum(1 for m in s.get("messages",[]) if m["role"]=="user") for s in sessions)

            k1, k2, k3, k4 = st.columns(4)
            kpi_style = "background:rgba(56,189,248,0.08);border:1px solid rgba(56,189,248,0.2);border-radius:12px;padding:16px;text-align:center"
            with k1:
                st.markdown(f"<div style='{kpi_style}'><div style='font-size:2rem;font-weight:900;color:#38bdf8'>{sum(counts.values())}</div><div style='color:#64748b;font-size:0.8rem'>Total Memories</div></div>", unsafe_allow_html=True)
            with k2:
                st.markdown(f"<div style='{kpi_style}'><div style='font-size:2rem;font-weight:900;color:#a78bfa'>{len(sessions)}</div><div style='color:#64748b;font-size:0.8rem'>Conversations</div></div>", unsafe_allow_html=True)
            with k3:
                st.markdown(f"<div style='{kpi_style}'><div style='font-size:2rem;font-weight:900;color:#34d399'>{total_user}</div><div style='color:#64748b;font-size:0.8rem'>Questions Asked</div></div>", unsafe_allow_html=True)
            with k4:
                st.markdown(f"<div style='{kpi_style}'><div style='font-size:2rem;font-weight:900;color:#fb923c'>{len(counts)}</div><div style='color:#64748b;font-size:0.8rem'>Memory Categories</div></div>", unsafe_allow_html=True)

            st.markdown("<br>", unsafe_allow_html=True)
            col_l, col_r = st.columns(2)

            with col_l:
                if counts:
                    fig_pie = px.pie(
                        names=list(counts.keys()), values=list(counts.values()),
                        title="🧠 Memory by Category",
                        color_discrete_sequence=px.colors.sequential.Plasma_r,
                        hole=0.45
                    )
                    fig_pie.update_layout(
                        paper_bgcolor="rgba(0,0,0,0)", plot_bgcolor="rgba(0,0,0,0)",
                        font_color="#e2e8f0", title_font_size=14,
                        margin=dict(t=40, b=10, l=10, r=10),
                        legend=dict(font=dict(color="#94a3b8"))
                    )
                    st.plotly_chart(fig_pie, use_container_width=True)
                else:
                    st.info("No memories yet — add some in Brain Explorer!")

            with col_r:
                if sessions:
                    sess_labels = [s.get("title","")[:20]+"…" for s in sessions[:10]]
                    sess_counts = [len(s.get("messages",[])) for s in sessions[:10]]
                    fig_bar = go.Figure(go.Bar(
                        x=sess_counts, y=sess_labels, orientation="h",
                        marker_color="#38bdf8", marker_line_width=0,
                        text=sess_counts, textposition="outside"
                    ))
                    fig_bar.update_layout(
                        title="💬 Messages per Conversation",
                        paper_bgcolor="rgba(0,0,0,0)", plot_bgcolor="rgba(0,0,0,0)",
                        font_color="#e2e8f0", title_font_size=14,
                        margin=dict(t=40, b=10, l=10, r=10),
                        xaxis=dict(showgrid=False, color="#475569"),
                        yaxis=dict(color="#94a3b8"),
                        height=300
                    )
                    st.plotly_chart(fig_bar, use_container_width=True)
                else:
                    st.info("No conversations yet — start chatting!")

        except Exception as ex:
            st.error(f"Analytics error: {ex}")

    # ─── TAB: GOALS & HABITS ────────────────────────────────────────────────
    with tab_goals:
        st.markdown("""
        <div style='background:linear-gradient(135deg,rgba(52,211,153,0.1),rgba(16,185,129,0.07));
        border:1px solid rgba(52,211,153,0.25);border-radius:16px;padding:18px 24px;margin-bottom:20px'>
        <h3 style='color:#34d399;margin:0 0 4px 0'>🎯 Goals & Habits Tracker</h3>
        <p style='color:#64748b;margin:0;font-size:0.88rem'>Set goals, track progress, and let your Twin keep you accountable.</p>
        </div>""", unsafe_allow_html=True)

        g_left, g_right = st.columns([0.38, 0.62])

        with g_left:
            st.markdown("#### ➕ Add New Goal")
            new_goal = st.text_area("Goal description", placeholder="e.g. Run 5km every day", height=90, key="new_goal_text")
            goal_cat = st.selectbox("Category", ["Health & Fitness", "Learning", "Career", "Personal", "Finance", "Relationships", "Other"], key="goal_cat")
            if st.button("🎯 Add Goal", key="add_goal_btn", use_container_width=True):
                if new_goal.strip():
                    try:
                        requests.post("http://127.0.0.1:8000/goals/add", json={
                            "user_id": st.session_state.email,
                            "goal": new_goal.strip(),
                            "category": goal_cat
                        })
                        st.success("✅ Goal added!")
                        st.rerun()
                    except Exception as ex:
                        st.error(f"Error: {ex}")
                else:
                    st.warning("Please enter a goal first.")

        with g_right:
            st.markdown("#### 📋 Your Goals")
            try:
                goals_res = requests.get(f"http://127.0.0.1:8000/goals?user_id={st.session_state.email}", timeout=4).json()
                goals_list = goals_res.get("goals", [])

                cat_icons = {"Health & Fitness":"💪","Learning":"📚","Career":"💼","Personal":"🌱","Finance":"💰","Relationships":"❤️","Other":"🎯"}

                if not goals_list:
                    st.info("No goals yet — add your first goal on the left!")
                else:
                    for goal in goals_list:
                        gid      = goal["_id"]
                        gtitle   = goal.get("goal","")
                        gcat     = goal.get("category","Other")
                        gprog    = goal.get("progress", 0)
                        gdone    = goal.get("completed", False)
                        icon     = cat_icons.get(gcat, "🎯")
                        bar_col  = "#34d399" if gdone else "#38bdf8"
                        done_badge = "<span style='background:#34d399;color:#0f172a;padding:2px 8px;border-radius:12px;font-size:0.7rem;font-weight:700'>✓ DONE</span>" if gdone else ""

                        st.markdown(f"""
                        <div style='background:rgba(52,211,153,0.06);border:1px solid rgba(52,211,153,0.18);
                        border-left:4px solid {bar_col};border-radius:12px;padding:14px 16px;margin-bottom:10px'>
                            <div style='display:flex;justify-content:space-between;align-items:center;margin-bottom:8px'>
                                <span style='color:#e2e8f0;font-weight:600'>{icon} {gtitle}</span>
                                {done_badge}
                            </div>
                            <div style='background:rgba(255,255,255,0.08);border-radius:6px;height:8px;overflow:hidden'>
                                <div style='background:linear-gradient(90deg,{bar_col},{bar_col}99);height:100%;width:{min(gprog,100)}%;border-radius:6px;transition:width 0.4s'></div>
                            </div>
                            <div style='display:flex;justify-content:space-between;margin-top:4px'>
                                <span style='color:#64748b;font-size:0.72rem'>{gcat}</span>
                                <span style='color:{bar_col};font-size:0.72rem;font-weight:700'>{gprog}%</span>
                            </div>
                        </div>""", unsafe_allow_html=True)

                        with st.expander(f"Update · {gtitle[:30]}…" if len(gtitle) > 30 else f"Update · {gtitle}"):
                            new_prog = st.slider("Progress %", 0, 100, gprog, key=f"prog_{gid}")
                            note_txt = st.text_input("Add a note (optional)", key=f"note_{gid}")
                            ucol1, ucol2 = st.columns(2)
                            with ucol1:
                                if st.button("💾 Save", key=f"save_goal_{gid}", use_container_width=True):
                                    requests.post("http://127.0.0.1:8000/goals/update", json={
                                        "goal_id": gid, "progress": new_prog,
                                        "note": note_txt
                                    })
                                    st.rerun()
                            with ucol2:
                                if st.button("🗑️ Delete", key=f"del_goal_{gid}", use_container_width=True):
                                    requests.delete(f"http://127.0.0.1:8000/goals/{gid}",
                                                    params={"user_id": st.session_state.email})
                                    st.rerun()
            except Exception as ex:
                st.error(f"Error loading goals: {ex}")

    # ─── TAB: CALENDAR ──────────────────────────────────────────────────────
    with tab_calendar:
        import datetime as _cal_dt

        st.markdown("""
        <div style='background:linear-gradient(135deg,rgba(251,191,36,0.1),rgba(249,115,22,0.08));
        border:1px solid rgba(251,191,36,0.25);border-radius:16px;padding:18px 24px;margin-bottom:20px'>
        <h3 style='color:#fbbf24;margin:0 0 4px 0'>📅 Smart Calendar</h3>
        <p style='color:#64748b;margin:0;font-size:0.88rem'>Add events, get reminders, and let your Twin manage your schedule.</p>
        </div>""", unsafe_allow_html=True)

        cal_left, cal_right = st.columns([0.38, 0.62])

        with cal_left:
            st.markdown("#### ➕ Add Event")
            ev_title = st.text_input("Event title", placeholder="Team meeting", key="ev_title")
            ev_date  = st.date_input("Date", value=_cal_dt.date.today(), key="ev_date")
            ev_time  = st.time_input("Time", value=_cal_dt.time(9, 0), key="ev_time")
            ev_desc  = st.text_area("Description (optional)", height=70, key="ev_desc")
            ev_color = st.color_picker("Color tag", value="#38bdf8", key="ev_color")
            if st.button("📅 Add Event", key="add_ev_btn", use_container_width=True):
                if ev_title.strip():
                    try:
                        requests.post("http://127.0.0.1:8000/calendar/add", json={
                            "user_id": st.session_state.email,
                            "title": ev_title.strip(),
                            "date": str(ev_date),
                            "time": str(ev_time),
                            "description": ev_desc,
                            "color": ev_color,
                        })
                        st.success("✅ Event added!")
                        st.rerun()
                    except Exception as ex:
                        st.error(f"Error: {ex}")
                else:
                    st.warning("Please enter an event title.")

        with cal_right:
            st.markdown("#### 🗓️ Upcoming Events")
            try:
                ev_res  = requests.get("http://127.0.0.1:8000/calendar/events",
                                       params={"user_id": st.session_state.email}, timeout=4).json()
                ev_list = ev_res.get("events", [])

                today_str = str(_cal_dt.date.today())
                upcoming  = [e for e in ev_list if e.get("date","") >= today_str]
                past      = [e for e in ev_list if e.get("date","") < today_str]

                if not ev_list:
                    st.info("No events yet — add your first event on the left!")
                else:
                    today_evs = [e for e in upcoming if e.get("date","") == today_str]
                    if today_evs:
                        st.markdown(f"<div style='background:rgba(251,191,36,0.12);border:1px solid rgba(251,191,36,0.3);border-radius:10px;padding:10px 14px;margin-bottom:12px'><span style='color:#fbbf24;font-weight:700'>📌 Today — {_cal_dt.date.today().strftime('%d %b %Y')}</span></div>", unsafe_allow_html=True)
                        for ev in today_evs:
                            st.markdown(f"""<div style='border-left:4px solid {ev.get("color","#38bdf8")};padding:8px 14px;margin-bottom:6px;background:rgba(255,255,255,0.04);border-radius:0 8px 8px 0'>
                            <span style='color:#e2e8f0;font-weight:600'>{ev["title"]}</span>
                            <span style='color:#64748b;font-size:0.78rem;margin-left:8px'>🕐 {ev.get("time","")}</span>
                            </div>""", unsafe_allow_html=True)

                    if upcoming:
                        st.markdown("**⏭ Upcoming**")
                        for ev in upcoming[:15]:
                            ev_id      = ev["_id"]
                            ev_date_fmt = _cal_dt.datetime.strptime(ev["date"], "%Y-%m-%d").strftime("%d %b %Y")
                            is_today   = ev["date"] == today_str
                            ev_col, del_col = st.columns([0.85, 0.15])
                            with ev_col:
                                st.markdown(f"""<div style='border-left:4px solid {ev.get("color","#38bdf8")};
                                padding:10px 14px;margin-bottom:6px;background:rgba(255,255,255,0.04);border-radius:0 10px 10px 0'>
                                <div style='color:#e2e8f0;font-weight:600'>{"📌 " if is_today else ""}{ev["title"]}</div>
                                <div style='color:#64748b;font-size:0.75rem'>📅 {ev_date_fmt} {"at "+ev.get("time","") if ev.get("time") else ""}</div>
                                {"<div style='color:#94a3b8;font-size:0.78rem;margin-top:4px'>"+ev["description"]+"</div>" if ev.get("description") else ""}
                                </div>""", unsafe_allow_html=True)
                            with del_col:
                                st.markdown("<div style='padding-top:8px'>", unsafe_allow_html=True)
                                if st.button("🗑️", key=f"del_ev_{ev_id}"):
                                    requests.delete(f"http://127.0.0.1:8000/calendar/event/{ev_id}",
                                                    params={"user_id": st.session_state.email})
                                    st.rerun()
                                st.markdown("</div>", unsafe_allow_html=True)

                    if past:
                        with st.expander(f"📁 Past events ({len(past)})"):
                            for ev in past[-10:]:
                                ev_date_fmt = _cal_dt.datetime.strptime(ev["date"], "%Y-%m-%d").strftime("%d %b %Y")
                                st.markdown(f"""<div style='border-left:3px solid rgba(100,116,139,0.5);
                                padding:8px 12px;margin-bottom:4px;opacity:0.6'>
                                <span style='color:#94a3b8;font-size:0.85rem'>{ev["title"]} — {ev_date_fmt}</span>
                                </div>""", unsafe_allow_html=True)

            except Exception as ex:
                st.error(f"Error loading events: {ex}")

# end layout